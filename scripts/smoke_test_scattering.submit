#!/bin/bash
#SBATCH --time=00:45:00
#SBATCH --job-name=kan_smoke_scattering
#SBATCH --ntasks=1
#SBATCH --nodes=1
#SBATCH --account=cai_ivs
#SBATCH --partition=gpu
#SBATCH --gres=gpu:1
#SBATCH --mem=64G
#SBATCH --output=/cluster/home/baumgnoa/log/%j_%N_smoke_scattering.out
#SBATCH --error=/cluster/home/baumgnoa/log/%j_%N_smoke_scattering.err
#SBATCH --export=ALL
#
# Quick end-to-end check that the new `scattering` reduction (kymatio) works
# on the cluster (kymatio import, CUDA forward/backward, real data) before
# committing to a full sweep. A handful of short DIRECT runs (no --multirun /
# no Optuna sweeper), 2 epochs each, logged to the shared MLflow server (same
# URL-file handoff as scripts/_tune_common.sh) — so the mlflow_server job
# (scripts/mlflow_server.submit) must already be running.
#
# Submit: sbatch scripts/smoke_test_scattering.submit
# Models to test: MODELS="efficientkan wavkan" sbatch scripts/smoke_test_scattering.submit

set -euo pipefail
export PYTHONUNBUFFERED=1
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
module load uv/0.10.10
cd /cluster/home/baumgnoa/kan-weak-lensing

export UV_PROJECT_ENVIRONMENT=/cluster/home/baumgnoa/kan-weak-lensing/.venv
export UV_PYTHON_DOWNLOADS=manual
export UV_PYTHON_PREFERENCE=only-managed
uv python install 3.12
uv sync

# Wait for the mlflow server job to publish its URL (same handoff as
# scripts/_tune_common.sh).
URL_FILE=/cluster/home/baumgnoa/kan-weak-lensing/mlflow/server_url.txt
for i in $(seq 1 60); do
  if [[ -s "${URL_FILE}" ]]; then break; fi
  echo "Waiting for MLflow URL at ${URL_FILE} (${i}/60)..."
  sleep 10
done
if [[ ! -s "${URL_FILE}" ]]; then
  echo "MLflow URL file never appeared; is the mlflow_server job running?" >&2
  exit 1
fi
TRACKING_URI=$(cat "${URL_FILE}")
echo "Using MLFLOW_TRACKING_URI=${TRACKING_URI}"

if [[ -n "${MODELS:-}" ]]; then
  read -r -a MODEL_LIST <<< "${MODELS}"
else
  MODEL_LIST=(efficientkan wavkan fasterkan fastkan)
fi

for MODEL in "${MODEL_LIST[@]}"; do
  echo "=== smoke test: ${MODEL} / scattering (J=3, order=2) ==="
  HYDRA_FULL_ERROR=1 uv run main.py \
    model="${MODEL}" \
    dataset=weak_lensing \
    dataset.reduction=scattering \
    dataset.scattering_J=3 \
    dataset.scattering_order=2 \
    training.epochs=2 \
    training.early_stopping=false \
    mlflow_tracking_uri="${TRACKING_URI}" \
    +experiment=smoke_test_scattering
done

# Edge cases of the swept J range (2..4) and order choice (1|2) — only on one
# model, just to prove they don't crash (input_dim/shape math at the extremes).
echo "=== smoke test: efficientkan / scattering (J=2, order=1, small edge) ==="
HYDRA_FULL_ERROR=1 uv run main.py \
  model=efficientkan \
  dataset=weak_lensing \
  dataset.reduction=scattering \
  dataset.scattering_J=2 \
  dataset.scattering_order=1 \
  training.epochs=2 \
  training.early_stopping=false \
  mlflow_tracking_uri="${TRACKING_URI}" \
  +experiment=smoke_test_scattering

echo "=== smoke test: efficientkan / scattering (J=4, order=2, large edge) ==="
HYDRA_FULL_ERROR=1 uv run main.py \
  model=efficientkan \
  dataset=weak_lensing \
  dataset.reduction=scattering \
  dataset.scattering_J=4 \
  dataset.scattering_order=2 \
  training.epochs=2 \
  training.early_stopping=false \
  mlflow_tracking_uri="${TRACKING_URI}" \
  +experiment=smoke_test_scattering

echo "=== all scattering smoke tests passed ==="
