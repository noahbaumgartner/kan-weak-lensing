#!/bin/bash
#SBATCH --time=00:30:00
#SBATCH --job-name=kan_test_kat_convstem
#SBATCH --ntasks=1
#SBATCH --nodes=1
#SBATCH --account=cai_ivs
#SBATCH --partition=gpu
#SBATCH --gres=gpu:1
#SBATCH --mem=64G
#SBATCH --output=/cluster/home/baumgnoa/log/%j_%N_test_kat_convstem.out
#SBATCH --error=/cluster/home/baumgnoa/log/%j_%N_test_kat_convstem.err
#SBATCH --export=ALL
#
# Short (non-sweep) KAT sanity check for the new learnable conv-stem
# front-end (src/modules/convstem.py): the model now reaches img_h x img_w
# (178x22) via strided Conv2d layers instead of a fixed bilinear resize,
# before patch_embed — same patch grid as before, only in_chans changes
# (1 -> stem_channels=8), wired in configs/model/kat.yaml.
#
# Unlike scripts/test_kkan_convstem.submit, this is deliberately NOT a
# from-a-real-sweep validation run: KAT+stem has never been run on a real GPU
# before (only a CPU dummy forward/backward with batch=2), so there are no
# trustworthy tuned hyperparameters yet, and KAT's KAT_Group rational
# activations are an unknown quantity memory-wise (KKAN's OOM turned out to
# be pre-existing and unrelated to the stem, but best not to assume the same
# holds here without checking). This is a quick "does it even run" check —
# few epochs, early stopping off, small batch — before committing to a full
# Stage 1 sweep (configs/sweep/image/tune_kat_arch.yaml, batch_size up to
# 256). If this succeeds, bump BATCH_SIZE to probe headroom the same way as
# scripts/test_kkan_convstem.submit; if it OOMs, scripts/debug_kkan_convstem.py
# is a template for a KAT-specific per-stage debug script.
#
# Submit: sbatch scripts/test_kat_convstem.submit
# Probe a different batch size: sbatch --export=ALL,BATCH_SIZE=32 scripts/test_kat_convstem.submit
# Override the MLflow experiment name: sbatch --export=ALL,EXPERIMENT=<name> scripts/test_kat_convstem.submit

set -euo pipefail
export PYTHONUNBUFFERED=1
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
module load uv/0.10.10
cd /cluster/home/baumgnoa/kan-weak-lensing

export UV_PROJECT_ENVIRONMENT=/cluster/home/baumgnoa/kan-weak-lensing/.venv
export UV_PYTHON_DOWNLOADS=manual
export UV_PYTHON_PREFERENCE=only-managed
uv python install 3.12
uv sync

# Wait for the mlflow server job to publish its URL (same handoff as
# scripts/_tune_common.sh / scripts/test_kkan_convstem.submit).
URL_FILE=/cluster/home/baumgnoa/kan-weak-lensing/mlflow/server_url.txt
for i in $(seq 1 60); do
  if [[ -s "${URL_FILE}" ]]; then break; fi
  echo "Waiting for MLflow URL at ${URL_FILE} (${i}/60)..."
  sleep 10
done
if [[ ! -s "${URL_FILE}" ]]; then
  echo "MLflow URL file never appeared; is the mlflow_server job running?" >&2
  exit 1
fi
TRACKING_URI=$(cat "${URL_FILE}")
echo "Using MLFLOW_TRACKING_URI=${TRACKING_URI}"

EXPERIMENT="${EXPERIMENT:-wl_mse_kat_convstem_smoke}"
BATCH_SIZE="${BATCH_SIZE:-16}"
echo "Using training.batch_size=${BATCH_SIZE}"

HYDRA_FULL_ERROR=1 uv run main.py \
  model=kat \
  dataset=weak_lensing \
  objective=mse \
  seed=42 \
  training.epochs=3 \
  training.batch_size="${BATCH_SIZE}" \
  training.early_stopping=false \
  optimizer=adam \
  mlflow_tracking_uri="${TRACKING_URI}" \
  +experiment="${EXPERIMENT}"

echo "=== kat conv-stem sanity check complete ==="
