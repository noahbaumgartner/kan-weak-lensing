#!/bin/bash
#SBATCH --time=06:00:00
#SBATCH --job-name=kan_test_best_efficientkan
#SBATCH --ntasks=1
#SBATCH --nodes=1
#SBATCH --account=cai_ivs
#SBATCH --partition=gpu
#SBATCH --gres=gpu:1
#SBATCH --mem=64G
#SBATCH --output=/cluster/home/baumgnoa/log/%j_%N_test_best_efficientkan.out
#SBATCH --error=/cluster/home/baumgnoa/log/%j_%N_test_best_efficientkan.err
#SBATCH --export=ALL
#
# Single (non-sweep) run of the best-scoring EfficientKAN config from the
# obj_mse study (run "shape [6873, 389, 2]", AdamW, grid_size 26). Reproduces
# that exact model and now logs the *honest* per-parameter metrics added to the
# trainer: final_test_r2_om / _s8 / _macro and final_test_mse_std_* (the
# leaderboard-comparable "MEAN MSE (STANDARDIZED)" = 1 − R²).
#
# NOTE: this is the MSE objective — the model outputs only the 2 point
# estimates (Ω_m, S_8), no σ. It is a point-estimate baseline and CANNOT be
# submitted to the Phase-1 Codabench leaderboard, which needs uncertainties.
# For a submittable model train with objective=score (4 outputs).
#
# Submit:  sbatch --export=ALL,EXPERIMENT=obj_mse_best scripts/test_best_efficientkan.submit
set -euo pipefail

EXPERIMENT="${EXPERIMENT:-obj_mse_best}"

export PYTHONUNBUFFERED=1
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
module load uv/0.10.10
cd /cluster/home/baumgnoa/kan-weak-lensing

export UV_PROJECT_ENVIRONMENT=/cluster/home/baumgnoa/kan-weak-lensing/.venv
export UV_PYTHON_DOWNLOADS=manual
export UV_PYTHON_PREFERENCE=only-managed
uv python install 3.12

# Recreate the venv if it was built against system Python (Triton needs Python.h).
if [[ -d "${UV_PROJECT_ENVIRONMENT}" ]]; then
  base_prefix=$("${UV_PROJECT_ENVIRONMENT}/bin/python" -c "import sys; print(sys.base_prefix)" 2>/dev/null || echo "")
  if [[ "${base_prefix}" != *"/uv/python/"* ]]; then
    echo "Recreating venv with uv-managed Python (was: ${base_prefix:-missing})"
    rm -rf "${UV_PROJECT_ENVIRONMENT}"
  fi
fi
uv sync

# Wait for the mlflow server job to publish its URL.
URL_FILE=/cluster/home/baumgnoa/kan-weak-lensing/mlflow/server_url.txt
for i in $(seq 1 60); do
  if [[ -s "${URL_FILE}" ]]; then break; fi
  echo "Waiting for MLflow URL at ${URL_FILE} (${i}/60)..."
  sleep 10
done
if [[ ! -s "${URL_FILE}" ]]; then
  echo "MLflow URL file never appeared; is the mlflow_server job running?" >&2
  exit 1
fi
export MLFLOW_TRACKING_URI=$(cat "${URL_FILE}")
echo "Using MLFLOW_TRACKING_URI=${MLFLOW_TRACKING_URI}"

echo "=== Re-running best EfficientKAN (obj_mse) -> experiment=${EXPERIMENT} ==="
HYDRA_FULL_ERROR=1 uv run main.py \
  model=efficientkan \
  objective=mse \
  optimizer=adamw \
  optimizer.lr=3.133145588286068e-05 \
  optimizer.weight_decay=4.645271918053348e-06 \
  model.n_hidden_layers=1 \
  model.hidden_width_0=389 \
  model.grid_size=26 \
  model.k=3 \
  dataset.reduction=avgpool \
  dataset.pool_stride=6 \
  dataset.conv_channels=67 \
  dataset.conv_layers=3 \
  dataset.conv_kernel=7 \
  training=adam \
  training.epochs=50 \
  seed=42 \
  mlflow_tracking_uri="${MLFLOW_TRACKING_URI}" \
  +experiment="${EXPERIMENT}"

echo "=== Done. Check ${EXPERIMENT} in MLflow for final_test_r2_macro / final_test_mse_std_mean ==="
